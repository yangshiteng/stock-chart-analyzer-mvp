{
  "manifest_version": 3,
  "name": "Stock Chart Analyzer MVP",
  "description": "Chrome extension that screenshots a TradingView chart on a fixed cadence, sends it to OpenAI for an executable day-trading signal, and shows the result in the side panel.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "icons": {
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "alarms",
    "notifications",
    "offscreen",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Stock Chart Analyzer",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
